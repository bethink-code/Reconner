{
  "buildCommand": "node build.mjs",
  "installCommand": "npm install",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "www.lekana.app" }],
      "destination": "https://lekana.app/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/api/request-access",
      "destination": "https://work.lekana.app/api/request-access"
    },
    {
      "source": "/api/contact",
      "destination": "https://work.lekana.app/api/contact"
    },
    {
      "source": "/api/pilot-application",
      "destination": "https://work.lekana.app/api/pilot-application"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*).vcf",
      "headers": [
        { "key": "Content-Type", "value": "text/vcard; charset=utf-8" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" }
      ]
    }
  ]
}
